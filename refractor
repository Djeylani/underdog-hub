import React, { useState, useEffect, useMemo } from 'react';
import { Search, Cpu, HardDrive, Star, Download, ExternalLink, Info, AlertTriangle, ChevronRight, LayoutGrid, List } from 'lucide-react';

/**
 * UNDERDOG HUB
 * A discovery tool for Large Language Models that actually fit on your hardware.
 * Focuses on VRAM efficiency and local deployment.
 */

const App = () => {
  const [models, setModels] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [searchQuery, setSearchQuery] = useState('');
  const [vramBudget, setVramBudget] = useState(6); // Default 6GB
  const [quantization, setQuantization] = useState(4); // Default 4-bit
  const [viewMode, setViewMode] = useState('grid');
  
  // App Constants
  const API_URL = "https://huggingface.co/api/models";
  const APP_ID = typeof __app_id !== 'undefined' ? __app_id : 'underdog-hub';

  // Fetch models from Hugging Face
  useEffect(() => {
    const fetchModels = async () => {
      setLoading(true);
      try {
        // We fetch text-generation models sorted by downloads to find the "best" ones
        const params = new URLSearchParams({
          filter: 'text-generation',
          sort: 'downloads',
          direction: '-1',
          limit: '100',
          full: 'true',
          config: 'true'
        });

        const response = await fetch(`${API_URL}?${params}`);
        if (!response.ok) throw new Error('Failed to fetch from Hugging Face');
        
        const data = await response.json();
        
        // Process data to extract parameter counts
        const processed = data.map(m => {
          // Try to find parameter count in tags or config
          let paramsCount = 0;
          
          // Check tags for things like "7b", "1.3b"
          const pTag = m.tags?.find(t => /^[0-9.]+[Bb]$/.test(t));
          if (pTag) {
            paramsCount = parseFloat(pTag.replace(/[Bb]/g, ''));
          } else if (m.id.toLowerCase().includes('7b')) {
            paramsCount = 7;
          } else if (m.id.toLowerCase().includes('1b')) {
            paramsCount = 1;
          } else if (m.id.toLowerCase().includes('3b')) {
            paramsCount = 3;
          } else if (m.id.toLowerCase().includes('8b')) {
            paramsCount = 8;
          } else if (m.id.toLowerCase().includes('11b')) {
            paramsCount = 11;
          } else if (m.id.toLowerCase().includes('13b')) {
            paramsCount = 13;
          } else {
            // Fallback: search for small models by name if no tag
            paramsCount = 0.5; 
          }

          return {
            id: m.id,
            name: m.id.split('/').pop(),
            author: m.id.split('/')[0],
            downloads: m.downloads,
            likes: m.likes,
            params: paramsCount,
            tags: m.tags || [],
            lastModified: new Date(m.lastModified).toLocaleDateString()
          };
        });

        setModels(processed);
      } catch (err) {
        setError(err.message);
      } finally {
        setLoading(false);
      }
    };

    fetchModels();
  }, []);

  // Calculation Logic: RAM needed = (Params * Bits/8) * 1.2 (overhead)
  const calculateVram = (params, bits) => {
    if (!params) return 0;
    const baseSize = (params * bits) / 8;
    return (baseSize * 1.2).toFixed(2); // 20% overhead for context/KV cache
  };

  // Filter models
  const filteredModels = useMemo(() => {
    return models.filter(model => {
      const vramRequired = calculateVram(model.params, quantization);
      const matchesVram = vramRequired <= vramBudget;
      const matchesSearch = model.id.toLowerCase().includes(searchQuery.toLowerCase());
      return matchesVram && matchesSearch;
    });
  }, [models, vramBudget, quantization, searchQuery]);

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900 font-sans">
      {/* Navbar */}
      <nav className="sticky top-0 z-50 bg-white border-b border-slate-200 px-4 py-3 flex flex-wrap items-center justify-between gap-4">
        <div className="flex items-center gap-2">
          <div className="bg-indigo-600 p-2 rounded-lg">
            <Cpu className="text-white w-6 h-6" />
          </div>
          <h1 className="text-xl font-bold tracking-tight text-slate-800">Underdog Hub</h1>
        </div>
        
        <div className="flex-1 max-w-xl relative">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 w-5 h-5" />
          <input 
            type="text"
            placeholder="Search Llama, Phi, Qwen..."
            className="w-full pl-10 pr-4 py-2 bg-slate-100 border-transparent focus:bg-white focus:border-indigo-500 rounded-full transition-all outline-none text-sm"
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
          />
        </div>

        <div className="flex items-center gap-2">
          <button 
            onClick={() => setViewMode('grid')}
            className={`p-2 rounded-md ${viewMode === 'grid' ? 'bg-indigo-50 text-indigo-600' : 'text-slate-500'}`}
          >
            <LayoutGrid size={20} />
          </button>
          <button 
            onClick={() => setViewMode('list')}
            className={`p-2 rounded-md ${viewMode === 'list' ? 'bg-indigo-50 text-indigo-600' : 'text-slate-500'}`}
          >
            <List size={20} />
          </button>
        </div>
      </nav>

      <main className="max-w-7xl mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-4 gap-8">
        
        {/* Sidebar Controls */}
        <aside className="lg:col-span-1 space-y-6">
          <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
            <h2 className="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-4 flex items-center gap-2">
              <HardDrive className="w-4 h-4" /> Hardware Limits
            </h2>
            
            <div className="space-y-6">
              <div>
                <div className="flex justify-between mb-2">
                  <label className="text-sm font-medium">VRAM Budget</label>
                  <span className="text-indigo-600 font-bold">{vramBudget} GB</span>
                </div>
                <input 
                  type="range" 
                  min="2" 
                  max="24" 
                  step="1"
                  value={vramBudget}
                  onChange={(e) => setVramBudget(parseInt(e.target.value))}
                  className="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
                />
                <div className="flex justify-between text-[10px] text-slate-400 mt-1">
                  <span>Mobile/Entry</span>
                  <span>Mid-Range</span>
                  <span>Enthusiast</span>
                </div>
              </div>

              <div>
                <label className="text-sm font-medium block mb-2">Quantization (Precision)</label>
                <div className="grid grid-cols-3 gap-2">
                  {[4, 8, 16].map((bit) => (
                    <button
                      key={bit}
                      onClick={() => setQuantization(bit)}
                      className={`py-2 text-xs rounded-lg border transition-all ${
                        quantization === bit 
                        ? 'bg-indigo-600 border-indigo-600 text-white shadow-md shadow-indigo-200' 
                        : 'bg-white border-slate-200 text-slate-600 hover:border-indigo-300'
                      }`}
                    >
                      {bit}-bit
                    </button>
                  ))}
                </div>
                <p className="text-[11px] text-slate-500 mt-2 italic">
                  Lower bits use less VRAM but lose slight intelligence.
                </p>
              </div>
            </div>
          </div>

          <div className="bg-indigo-900 text-indigo-100 p-6 rounded-2xl shadow-lg relative overflow-hidden">
            <div className="relative z-10">
              <h3 className="font-bold text-white mb-2">Underdog Tip</h3>
              <p className="text-xs leading-relaxed opacity-90">
                If you have 6GB VRAM, look for <strong>8B parameter</strong> models in <strong>4-bit</strong> quantization. These usually feel like "Mini ChatGPT" and run quite fast.
              </p>
            </div>
            <div className="absolute -bottom-4 -right-4 opacity-10">
              <Cpu size={120} />
            </div>
          </div>
        </aside>

        {/* Content Area */}
        <section className="lg:col-span-3">
          <div className="flex justify-between items-center mb-6">
            <div>
              <h2 className="text-2xl font-bold text-slate-800">
                {filteredModels.length} Compatible Models
              </h2>
              <p className="text-slate-500 text-sm">Sorted by popularity on Hugging Face</p>
            </div>
          </div>

          {loading ? (
            <div className="flex flex-col items-center justify-center py-24 opacity-50">
              <div className="w-12 h-12 border-4 border-indigo-600 border-t-transparent rounded-full animate-spin mb-4"></div>
              <p>Scouring the Hub for you...</p>
            </div>
          ) : error ? (
            <div className="bg-red-50 text-red-700 p-8 rounded-2xl border border-red-100 flex flex-col items-center text-center">
              <AlertTriangle className="w-12 h-12 mb-4" />
              <h3 className="font-bold text-lg">Connection Error</h3>
              <p className="max-w-md mx-auto">{error}</p>
              <button 
                onClick={() => window.location.reload()}
                className="mt-4 px-6 py-2 bg-red-600 text-white rounded-full text-sm font-medium"
              >
                Retry
              </button>
            </div>
          ) : filteredModels.length === 0 ? (
            <div className="bg-white p-12 rounded-2xl border border-slate-200 text-center">
              <Search className="w-12 h-12 text-slate-300 mx-auto mb-4" />
              <h3 className="text-lg font-semibold text-slate-800">No Underdogs Found</h3>
              <p className="text-slate-500 max-w-sm mx-auto">Try increasing your VRAM budget or searching for smaller architectures like 'Phi' or 'Gemma'.</p>
            </div>
          ) : (
            <div className={viewMode === 'grid' ? "grid grid-cols-1 md:grid-cols-2 gap-4" : "space-y-3"}>
              {filteredModels.map((model) => {
                const required = calculateVram(model.params, quantization);
                const pctOfBudget = (required / vramBudget) * 100;
                
                return (
                  <div 
                    key={model.id}
                    className={`bg-white rounded-2xl border border-slate-200 hover:border-indigo-400 hover:shadow-xl hover:shadow-indigo-500/5 transition-all group overflow-hidden ${viewMode === 'list' ? 'flex items-center gap-4 p-4' : ''}`}
                  >
                    {viewMode === 'grid' && (
                      <div className="bg-slate-50 px-5 py-4 border-b border-slate-100 flex justify-between items-start">
                        <div className="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-sm border border-slate-200 font-bold text-indigo-600 text-xs">
                          {model.params}B
                        </div>
                        <div className="flex gap-3 text-[11px] text-slate-500 font-medium">
                          <span className="flex items-center gap-1"><Download size={14} /> {model.downloads.toLocaleString()}</span>
                          <span className="flex items-center gap-1"><Star size={14} /> {model.likes}</span>
                        </div>
                      </div>
                    )}

                    <div className={`p-5 flex-1`}>
                      <h3 className="font-bold text-slate-900 group-hover:text-indigo-600 truncate mb-1" title={model.id}>
                        {model.name}
                      </h3>
                      <p className="text-xs text-slate-400 mb-4">{model.author}</p>
                      
                      <div className="space-y-3">
                        <div className="flex justify-between text-xs">
                          <span className="text-slate-500">Memory Required</span>
                          <span className={`font-bold ${pctOfBudget > 90 ? 'text-orange-600' : 'text-emerald-600'}`}>
                            ~{required} GB
                          </span>
                        </div>
                        
                        <div className="w-full h-1.5 bg-slate-100 rounded-full overflow-hidden">
                          <div 
                            className={`h-full transition-all duration-1000 ${pctOfBudget > 90 ? 'bg-orange-400' : 'bg-emerald-400'}`}
                            style={{ width: `${Math.min(pctOfBudget, 100)}%` }}
                          />
                        </div>

                        <div className="flex flex-wrap gap-1 pt-2">
                          {model.tags.slice(0, 3).map(tag => (
                            <span key={tag} className="text-[10px] px-2 py-0.5 bg-slate-100 text-slate-500 rounded-full border border-slate-200">
                              {tag}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>

                    <div className={`px-5 py-3 bg-slate-50/50 border-t border-slate-100 flex items-center justify-between ${viewMode === 'list' ? 'border-t-0 border-l px-6' : ''}`}>
                       <a 
                        href={`https://huggingface.co/${model.id}`} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        className="text-xs font-semibold text-indigo-600 flex items-center gap-1 hover:underline"
                       >
                         View Card <ExternalLink size={12} />
                       </a>
                       <div className="text-[10px] text-slate-400">
                         {model.lastModified}
                       </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
          
          <div className="mt-12 p-8 bg-white border border-slate-200 rounded-3xl flex items-start gap-6">
            <div className="bg-orange-100 p-3 rounded-2xl text-orange-600">
              <Info className="w-6 h-6" />
            </div>
            <div>
              <h4 className="font-bold text-slate-900 mb-2">How we calculate compatibility</h4>
              <p className="text-sm text-slate-600 leading-relaxed mb-4">
                We use the formula: <code>(Parameters × Bits / 8) × 1.2</code>. 
                The 1.2x multiplier accounts for system overhead, activations, and the KV Cache needed to store the conversation context. 
                If you use a context window of 32k or higher, you may need even more VRAM than shown.
              </p>
              <div className="flex gap-4">
                <div className="flex flex-col">
                  <span className="text-xs font-bold text-slate-400 uppercase tracking-widest">Recommended Tools</span>
                  <div className="flex gap-2 mt-2">
                    {['Ollama', 'LM Studio', 'GPT4All', 'llama.cpp'].map(tool => (
                      <span key={tool} className="px-3 py-1 bg-slate-100 text-slate-700 text-[11px] font-medium rounded-lg border border-slate-200">
                        {tool}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      {/* Footer */}
      <footer className="border-t border-slate-200 mt-20 py-12 bg-white">
        <div className="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
          <div className="flex items-center gap-2 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all cursor-default">
            <Cpu size={20} />
            <span className="font-bold text-slate-600">Underdog Hub</span>
          </div>
          <p className="text-slate-400 text-xs">
            Built for the community with limited hardware. Scouring Hugging Face so you don't have to.
          </p>
          <div className="flex gap-4 text-xs font-medium text-slate-500">
            <a href="#" className="hover:text-indigo-600">Documentation</a>
            <a href="#" className="hover:text-indigo-600">FAQ</a>
            <a href="#" className="hover:text-indigo-600">Privacy</a>
          </div>
        </div>
      </footer>
    </div>
  );
};

export default App;